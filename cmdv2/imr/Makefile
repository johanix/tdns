PROG:=tdns-imr

GOOS ?= $(shell uname -s | tr A-Z a-z)
# CGO is required: the algorithms selected in algs.list are C-backed
# (liboqs/sqisign/qruov), linked via the genalgs-generated files.
GO:= CGO_ENABLED=1 go
include ../../utils/Makefile.common

# Algorithm build environment (PKG_CONFIG_PATH etc.) for the C-backed
# algorithms selected in algs.list. Generated by tdns-genalgs alongside
# metadata_algs.go / registered_algs.go — run the generator before make:
#   tdns-genalgs --algrepo=<dnssec-algorithms root> --list=algs.list --out=.
# -include (not include): absent on a fresh tree until the generator runs.
-include algs-env.mk

.PHONY: clean install

install:
	install -s -b -c ${PROG} /usr/local/bin/

clean:
	rm -f $(PROG)
	find . -type f -name '*~' -delete

